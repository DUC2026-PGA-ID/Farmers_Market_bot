BOT_TOKEN=123456789:replace-with-your-telegram-bot-token
WEBHOOK_SECRET=replace-with-a-random-secret-string
WEBHOOK_PATH=/telegram/webhook
AUTO_SET_WEBHOOK=true
ADMIN_USER_IDS=123456789,987654321
MYSQL_HOST=your-remote-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=farmers_market_bot
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=replace-with-your-mysql-password
# For local XAMPP testing only, MYSQL_HOST can be 127.0.0.1 and MYSQL_PASSWORD may be blank.
# Optional for non-Render hosting. Render sets RENDER_EXTERNAL_URL automatically.
WEBHOOK_URL=https://your-service.onrender.com
